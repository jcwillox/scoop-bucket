    "architecture": {
        "64bit": {
            "url": "https://github.com/Nexus-Mods/Vortex/releases/download/v2.2.0/vortex-setup-2.2.0.exe#/dl.7z",
            "hash": "sha512:8550c96331a2616b6ae5ca4eabe01ef58020e22d53604f06e5bb4f1f963630b6d62c3fd62d1ea3670abb6c95fa2836c741bc3e58f9ad20dfa43a850112974c37",
            "pre_install": [
                "Expand-7zipArchive \"$dir\\`$PLUGINSDIR\\app-64.7z\" \"$dir\"",
